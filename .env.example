# Gemini API Key (必須)
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here

# CoeiroInk設定
COEIROINK_HOST=http://localhost:50032
# リリンちゃん メスガキスタイル
COEIROINK_SPEAKER_UUID=cb11bdbd-78fc-4f16-b528-a400bae1782d
COEIROINK_STYLE_ID=92

# STT言語設定
STT_LANGUAGE=ja-JP

# 仮想オーディオケーブル設定（3teneリップシンク用）
# VB-Audio Virtual Cableのデバイス名を指定
VIRTUAL_CABLE_NAME=CABLE Input
